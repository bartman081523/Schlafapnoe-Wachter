<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base Theme -->
    <style name="Theme.ApneaApp" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorPrimaryVariant">@color/primaryDarkColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/secondaryColor</item>
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        
        <!-- Custom Attributes Mapping -->
        <item name="android:windowBackground">@color/backgroundColorLight</item>
    </style>

    <!-- Specific Style for Cards to support Night Mode -->
    <style name="Style.ApneaCard" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/cardColorLight</item>
        <item name="cardCornerRadius">12dp</item>
        <item name="cardElevation">2dp</item>
    </style>
</resources>