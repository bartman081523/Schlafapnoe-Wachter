<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/backgroundColor">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/tab_settings"
            android:textColor="@color/primaryDarkColor"
            android:textStyle="bold"
            android:textSize="24sp"
            android:layout_marginBottom="24dp"
            android:gravity="center"/>

        <!-- Lautstärke -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/cardColor"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/settings_volume" android:textColor="@color/textColorPrimary" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/txtVolumeVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="50%" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="16sp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/volumeSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="100" android:progress="50" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Stille -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/cardColor"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/settings_silence" android:textColor="@color/textColorPrimary" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/txtSilenceVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="250" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="16sp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/silenceSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="1000" android:progress="250" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Schnarchen -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/cardColor"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/settings_snore" android:textColor="@color/textColorPrimary" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/txtSnoreVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="1200" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="16sp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/snoreSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:max="5000" android:progress="1200" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Atempause -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/cardColor"
            android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/settings_trigger" android:textColor="@color/textColorPrimary" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/txtTriggerVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12s" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="16sp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/triggerSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:min="5" android:max="30" android:progress="12" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Abklingzeit -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/cardColor"
            android:layout_marginBottom="24dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="@string/settings_cooldown" android:textColor="@color/textColorPrimary" android:textSize="16sp" android:textStyle="bold"/>
                    <TextView android:id="@+id/txtCooldownVal" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15m" android:textStyle="bold" android:textColor="@color/primaryColor" android:textSize="16sp"/>
                </LinearLayout>
                <SeekBar android:id="@+id/cooldownSeekBar" android:layout_width="match_parent" android:layout_height="wrap_content" android:min="1" android:max="60" android:progress="15" android:layout_marginTop="16dp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnResetSettings"
            style="@style/Widget.MaterialComponents.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:text="@string/btn_reset"
            android:textColor="@color/textColorSecondary"
            android:textSize="16sp"
            android:layout_marginBottom="24dp"/>

    </LinearLayout>
</androidx.core.widget.NestedScrollView>